          stroke="currentColor"
          stroke-width="var(--icon-stroke-width)"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>

    <div
      class="lang_dropdown"
      role="listbox"
      aria-label="Selecionar idioma"
      hidden
    >
      {%- if current_prefix != 'pt' -%}
        <a
          class="lang_option"
          role="option"
          href="{{ base_path }}"
          hreflang="pt"
