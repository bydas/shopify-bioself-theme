          href="/en{{ base_path }}"
          hreflang="en"
          >English</a
        >
      {%- endif -%}

      {%- if current_prefix != 'es' -%}
        <a
          class="lang_option"
          role="option"
          href="/es{{ base_path }}"
          hreflang="es"
          >Español</a
        >
      {%- endif -%}
