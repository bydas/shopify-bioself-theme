  {%- liquid
    assign path = request.path
    assign base_path = path

    if path == '/en' or path contains '/en/'
      assign base_path = path | remove_first: '/en'
    elsif path == '/es' or path contains '/es/'
      assign base_path = path | remove_first: '/es'
    endif

    if base_path == ''
      assign base_path = '/'
    endif

    assign current_prefix = 'pt'
    if path == '/en' or path contains '/en/'
      assign current_prefix = 'en'
    elsif path == '/es' or path contains '/es/'
      assign current_prefix = 'es'
    endif
  -%}
