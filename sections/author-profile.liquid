{% liquid
  assign author_name = section.settings.author_name | strip
  assign author_bio = section.settings.author_bio
  assign author_image = section.settings.author_image
%}

<section class="author-profile author-profile-{{ section.id }}">
  <div class="author-profile__container">
    <div class="author-profile__header">
      {% if section.settings.label != blank %}
        <p class="author-profile__label">
          {{ section.settings.label }}
        </p>
      {% endif %}

      {% if author_image != blank %}
        <div class="author-profile__image-wrapper">
          {{
            author_image
            | image_url: width: 800
            | image_tag:
              class: 'author-profile__image',
              loading: 'lazy',
              widths: '240, 320, 400, 600, 800',
              sizes: '(max-width: 749px) 170px, 260px',
              alt: author_name
          }}
        </div>
      {% endif %}

      {% if author_name != blank %}
        <h1 class="author-profile__name">
          {{ author_name }}
        </h1>
      {% endif %}
    </div>

    {% if author_bio != blank %}
      <div class="author-profile__bio rte">
        {{ author_bio }}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .author-profile-{{ section.id }} {
    margin: 2rem var(--desktop-container-gutter);
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .author-profile-{{ section.id }} .author-profile__container {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .author-profile-{{ section.id }} .author-profile__header {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 24px;
  }

  .author-profile-{{ section.id }} .author-profile__label {
    margin: 0 0 14px;
    font-size: 11px;
    line-height: 1.4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.65;
  }

  .author-profile-{{ section.id }} .author-profile__image-wrapper {
    width: 260px;
    max-width: 260px;
    aspect-ratio: 1 / 1;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
    margin-bottom: 24px;
  }

  .author-profile-{{ section.id }} .author-profile__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .author-profile-{{ section.id }} .author-profile__name {
    margin: 0;
    font-size: clamp(34px, 4vw, 56px);
    line-height: 1.08;
    font-weight: 700;
    color: inherit;
  }

  .author-profile-{{ section.id }} .author-profile__bio {
    width: 100%;
    max-width: 620px;
    margin: 0 auto;
    text-align: left;
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.75;
    color: inherit;
    opacity: 0.85;
  }

  .author-profile-{{ section.id }} .author-profile__bio * {
    text-align: left;
  }

  .author-profile-{{ section.id }} .author-profile__bio p {
    margin-top: 0;
  }

  .author-profile-{{ section.id }} .author-profile__bio p:last-child {
    margin-bottom: 0;
  }

  @media screen and (min-width: 1499px) {
    .author-profile-{{ section.id }} {
      margin: 2rem 9vw;
    }

    .author-profile-{{ section.id }} .author-profile__container {
      max-width: 640px;
    }

    .author-profile-{{ section.id }} .author-profile__bio {
      max-width: 600px;
    }
  }

  @media screen and (min-width: 2559px) {
    .author-profile-{{ section.id }} {
      margin: 2rem 18vw;
    }
  }

  @media screen and (max-width: 749px) {
    .author-profile-{{ section.id }} {
      margin: 1rem var(--mobile-container-gutter);
    }

    .author-profile-{{ section.id }} .author-profile__container {
      max-width: 100%;
    }

    .author-profile-{{ section.id }} .author-profile__header {
      margin-bottom: 22px;
    }

    .author-profile-{{ section.id }} .author-profile__image-wrapper {
      width: 180px;
      max-width: 180px;
      margin-bottom: 20px;
    }

    .author-profile-{{ section.id }} .author-profile__name {
      font-size: clamp(30px, 9vw, 42px);
    }

    .author-profile-{{ section.id }} .author-profile__bio {
      max-width: 100%;
      font-size: 15px;
      line-height: 1.7;
    }
  }
</style>

{% schema %}
{
  "name": "Autor",
  "tag": "section",
  "class": "section-author-profile",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Autor"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Imagem do autor"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Nome do autor",
      "default": "Nome do autor"
    },
    {
      "type": "richtext",
      "id": "author_bio",
      "label": "Biografia",
      "default": "<p>Escreva aqui uma breve biografia do autor, destacando a sua experiência, percurso e ligação ao tema apresentado.</p>"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Arredondamento da imagem",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 160
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#F7F4EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Autor"
    }
  ]
}
{% endschema %}
