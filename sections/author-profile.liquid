{% liquid
  assign author_name = section.settings.author_name | strip
  assign author_bio = section.settings.author_bio
  assign author_image = section.settings.author_image
%}

<section class="author-profile author-profile-{{ section.id }}">
  <div class="author-profile__container">
    {% if author_image != blank %}
      <div class="author-profile__image-wrapper">
        {{
          author_image
          | image_url: width: 800
          | image_tag:
            class: 'author-profile__image',
            loading: 'lazy',
            widths: '300, 400, 600, 800',
            sizes: '(max-width: 749px) 180px, 320px',
            alt: author_name
        }}
      </div>
    {% endif %}

    <div class="author-profile__content">
      {% if section.settings.label != blank %}
        <p class="author-profile__label">
          {{ section.settings.label }}
        </p>
      {% endif %}

      {% if author_name != blank %}
        <h1 class="author-profile__name">
          {{ author_name }}
        </h1>
      {% endif %}

      {% if author_bio != blank %}
        <div class="author-profile__bio rte">
          {{ author_bio }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .author-profile-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .author-profile-{{ section.id }} .author-profile__container {
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: {% if author_image != blank %}320px 1fr{% else %}1fr{% endif %};
    gap: 48px;
    align-items: center;
  }

  .author-profile-{{ section.id }} .author-profile__image-wrapper {
    width: 100%;
    max-width: 320px;
    aspect-ratio: 1 / 1;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
  }

  .author-profile-{{ section.id }} .author-profile__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .author-profile-{{ section.id }} .author-profile__content {
    max-width: 720px;
  }

  .author-profile-{{ section.id }} .author-profile__label {
    margin: 0 0 12px;
    font-size: 13px;
    line-height: 1.4;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .author-profile-{{ section.id }} .author-profile__name {
    margin: 0 0 20px;
    font-size: clamp(32px, 5vw, 64px);
    line-height: 1.05;
    font-weight: 600;
    color: inherit;
  }

  .author-profile-{{ section.id }} .author-profile__bio {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.75;
    color: inherit;
    opacity: 0.85;
  }

  .author-profile-{{ section.id }} .author-profile__bio p {
    margin-top: 0;
  }

  .author-profile-{{ section.id }} .author-profile__bio p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .author-profile-{{ section.id }} {
      padding-left: 16px;
      padding-right: 16px;
    }

    .author-profile-{{ section.id }} .author-profile__container {
      grid-template-columns: 1fr;
      gap: 28px;
      text-align: {{ section.settings.mobile_alignment }};
    }

    .author-profile-{{ section.id }} .author-profile__image-wrapper {
      max-width: 180px;
      margin: 0 {% if section.settings.mobile_alignment == 'center' %}auto{% else %}0{% endif %};
    }
  }
</style>

{% schema %}
{
  "name": "Autor",
  "tag": "section",
  "class": "section-author-profile",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta",
      "default": "Autor"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Imagem do autor"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Nome do autor",
      "default": "Nome do autor"
    },
    {
      "type": "richtext",
      "id": "author_bio",
      "label": "Biografia",
      "default": "<p>Escreva aqui uma breve biografia do autor, destacando a sua experiência, percurso e ligação ao tema apresentado.</p>"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Largura máxima",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "default": 1100
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Arredondamento da imagem",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 160
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Alinhamento em mobile",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#F7F4EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Cor do texto",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaçamento superior",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaçamento inferior",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Autor"
    }
  ]
}
{% endschema %}
