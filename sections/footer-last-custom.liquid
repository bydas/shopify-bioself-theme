{% schema %}
{
  "name": "Custom last footer",
  "settings": [
    {
      "type": "header",
      "content": "Primeira imagem"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Selecionar primeira imagem"
    },
    {
      "type": "url",
      "id": "image_url",
      "label": "Link da primeira imagem"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Largura no computador",
      "min": 40,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Largura no telemóvel",
      "min": 40,
      "max": 500,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Segunda imagem"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Selecionar segunda imagem"
    },
    {
      "type": "url",
      "id": "image_url_2",
      "label": "Link da segunda imagem"
    },
    {
      "type": "range",
      "id": "image_2_width",
      "label": "Largura no computador",
      "min": 40,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "image_2_width_mobile",
      "label": "Largura no telemóvel",
      "min": 40,
      "max": 500,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "header",
      "content": "Texto da primeira imagem"
    },
    {
      "type": "textarea",
      "id": "multiline_text",
      "label": "Descrição"
    },
    {
      "type": "text",
      "id": "single_line_text",
      "label": "Título"
    }
  ],
  "presets": [
    {
      "name": "Custom last footer",
      "category": "Footer"
    }
  ]
}
{% endschema %}

<style>
  #custom_last_footer_{{ section.id }} {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    margin: 2rem var(--desktop-container-gutter);
    justify-content: space-between;
    align-items: start;
  }

  #custom_last_footer_mobile_{{ section.id }} {
    display: none;
    grid-template-rows: repeat(2, max-content);
    gap: 2rem;
    margin:
      2rem
      var(--mobile-container-gutter)
      6.5rem
      var(--mobile-container-gutter);
    align-items: center;
  }

  /*
   * No desktop, os elementos internos participam diretamente
   * na grelha principal: primeira imagem/texto, segunda imagem
   * e métodos de pagamento.
   */
  #custom_last_footer_{{ section.id }} .footer-content-column {
    display: contents;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-content-column {
    display: grid;
    grid-template-rows: repeat(2, max-content);
    gap: 1rem;
    width: 100%;
  }

  /*
   * Primeira imagem e respetivo texto.
   */
  #custom_last_footer_{{ section.id }} .footer-primary-row {
    display: grid;
    grid-template-columns: max-content minmax(0, max-content);
    grid-column: 1;
    grid-row: 1;
    gap: 1rem;
    align-items: center;
    justify-content: start;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-primary-row {
    display: grid;
    grid-template-columns: max-content minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
  }

  /*
   * No desktop, a segunda imagem fica à direita da primeira
   * imagem e do respetivo bloco de texto.
   */
  #custom_last_footer_{{ section.id }} .footer-secondary-row {
    display: flex;
    grid-column: 2;
    grid-row: 1;
    justify-content: flex-start;
    align-items: flex-start;
    width: 100%;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-secondary-row {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    width: 100%;
  }

  #custom_last_footer_{{ section.id }} .footer-custom-image-link,
  #custom_last_footer_mobile_{{ section.id }} .footer-custom-image-link {
    display: block;
    width: max-content;
    max-width: 100%;
    line-height: 0;
    text-decoration: none;
  }

  #custom_last_footer_{{ section.id }} .footer-custom-image,
  #custom_last_footer_mobile_{{ section.id }} .footer-custom-image {
    display: block;
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /*
   * Tamanhos definidos no editor do tema.
   */
  #custom_last_footer_{{ section.id }} .footer-image-1 {
    width: {{ section.settings.image_width }}px;
  }

  #custom_last_footer_{{ section.id }} .footer-image-2 {
    width: {{ section.settings.image_2_width }}px;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-image-1 {
    width: {{ section.settings.image_width_mobile }}px;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-image-2 {
    width: {{ section.settings.image_2_width_mobile }}px;
  }

  /*
   * Texto associado exclusivamente à primeira imagem.
   */
  #custom_last_footer_{{ section.id }} .footer-custom-text,
  #custom_last_footer_mobile_{{ section.id }} .footer-custom-text {
    display: grid;
    grid-template-rows: repeat(2, max-content);
    gap: 0.5rem;
    align-content: center;
  }

  #custom_last_footer_{{ section.id }} .footer-description {
    display: block;
    font-size: 12px;
    font-weight: 600;
  }

  #custom_last_footer_{{ section.id }} .footer-custom-title {
    display: block;
    font-size: 15px;
    margin: 0;
    font-weight: 600;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-description {
    display: block;
    font-size: 10px;
    max-width: 14rem;
    font-weight: 500;
  }

  #custom_last_footer_mobile_{{ section.id }} .footer-custom-title {
    display: block;
    font-size: 12px;
    margin: 0;
    max-width: 20rem;
    font-weight: 600;
  }

  /*
   * Métodos de pagamento.
   */
  #custom_last_footer_{{ section.id }} > ul,
  #custom_last_footer_mobile_{{ section.id }} > ul {
    list-style-type: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(50px, max-content));
    height: max-content;
    row-gap: 1rem;
    padding: 0;
    margin: 0;
  }

  #custom_last_footer_{{ section.id }} > ul {
    grid-column: 3;
    grid-row: 1;
    justify-content: right;
  }

  #custom_last_footer_mobile_{{ section.id }} > ul {
    justify-content: center;
  }

  #custom_last_footer_{{ section.id }} > ul > li,
  #custom_last_footer_mobile_{{ section.id }} > ul > li {
    display: grid;
    padding: 0;
    margin: 0;
  }

  @media screen and (max-width: 1599px) and (min-width: 1001px) {
    #custom_last_footer_{{ section.id }} .footer-description {
      font-size: 10px;
    }

    #custom_last_footer_{{ section.id }} .footer-custom-title {
      font-size: 13px;
    }
  }

  @media screen and (min-width: 1499px) {
    #custom_last_footer_{{ section.id }} {
      margin: 2rem 9vw;
    }
  }

  @media screen and (min-width: 2559px) {
    #custom_last_footer_{{ section.id }} {
      margin: 2rem 18vw;
    }
  }

  @media screen and (max-width: 1000px) {
    #custom_last_footer_{{ section.id }} {
      display: none;
    }

    #custom_last_footer_mobile_{{ section.id }} {
      display: grid;
    }
  }

  @media screen and (max-width: 480px) {
    #custom_last_footer_mobile_{{ section.id }} .footer-primary-row {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 1rem;
    }

    #custom_last_footer_mobile_{{ section.id }} .footer-custom-text {
      justify-items: center;
      text-align: center;
    }

    #custom_last_footer_mobile_{{ section.id }} .footer-description {
      max-width: 20rem;
      text-align: center;
    }

    #custom_last_footer_mobile_{{ section.id }} .footer-custom-title {
      max-width: 20rem;
      text-align: center;
    }

    #custom_last_footer_mobile_{{ section.id }} .footer-secondary-row {
      justify-content: center;
    }
  }

  @media screen and (max-width: 360px) {
    #custom_last_footer_mobile_{{ section.id }} .footer-description,
    #custom_last_footer_mobile_{{ section.id }} .footer-custom-title {
      max-width: 12rem;
    }
  }
</style>

{% assign alt_payments = 'mbway,multibanco' | split: ',' %}
{% assign new_payments = shop.enabled_payment_types | concat: alt_payments %}

<section id="custom_last_footer_{{ section.id }}">
  <div class="footer-content-column">
    <div class="footer-primary-row">
      {% if section.settings.image != blank %}
        {% if section.settings.image_url != blank %}
          <a
            class="footer-custom-image-link"
            href="{{ section.settings.image_url }}"
          >
            <img
              class="footer-custom-image footer-image-1"
              src="{{ section.settings.image | image_url: width: 1600 }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              alt="{{ section.settings.image.alt | default: 'Primeira imagem do rodapé' | escape }}"
              loading="lazy"
            >
          </a>
        {% else %}
          <img
            class="footer-custom-image footer-image-1"
            src="{{ section.settings.image | image_url: width: 1600 }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            alt="{{ section.settings.image.alt | default: 'Primeira imagem do rodapé' | escape }}"
            loading="lazy"
          >
        {% endif %}
      {% endif %}

      {% if section.settings.multiline_text != blank or section.settings.single_line_text != blank %}
        <div class="footer-custom-text">
          {% if section.settings.multiline_text != blank %}
            <span class="footer-description">
              {{ section.settings.multiline_text }}
            </span>
          {% endif %}

          {% if section.settings.single_line_text != blank %}
            <span class="footer-custom-title">
              {{ section.settings.single_line_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.image_2 != blank %}
      <div class="footer-secondary-row">
        {% if section.settings.image_url_2 != blank %}
          <a
            class="footer-custom-image-link"
            href="{{ section.settings.image_url_2 }}"
          >
            <img
              class="footer-custom-image footer-image-2"
              src="{{ section.settings.image_2 | image_url: width: 1600 }}"
              width="{{ section.settings.image_2.width }}"
              height="{{ section.settings.image_2.height }}"
              alt="{{ section.settings.image_2.alt | default: 'Segunda imagem do rodapé' | escape }}"
              loading="lazy"
            >
          </a>
        {% else %}
          <img
            class="footer-custom-image footer-image-2"
            src="{{ section.settings.image_2 | image_url: width: 1600 }}"
            width="{{ section.settings.image_2.width }}"
            height="{{ section.settings.image_2.height }}"
            alt="{{ section.settings.image_2.alt | default: 'Segunda imagem do rodapé' | escape }}"
            loading="lazy"
          >
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% unless new_payments.size == 0 %}
    <ul>
      {% for payment in new_payments %}
        <li>
          {{ payment | payment_type_svg_tag }}
        </li>
      {% endfor %}
    </ul>
  {% endunless %}
</section>

<section id="custom_last_footer_mobile_{{ section.id }}">
  {% unless new_payments.size == 0 %}
    <ul>
      {% for payment in new_payments %}
        <li>
          {{ payment | payment_type_svg_tag }}
        </li>
      {% endfor %}
    </ul>
  {% endunless %}

  <div class="footer-content-column">
    <div class="footer-primary-row">
      {% if section.settings.image != blank %}
        {% if section.settings.image_url != blank %}
          <a
            class="footer-custom-image-link"
            href="{{ section.settings.image_url }}"
          >
            <img
              class="footer-custom-image footer-image-1"
              src="{{ section.settings.image | image_url: width: 1000 }}"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
              alt="{{ section.settings.image.alt | default: 'Primeira imagem do rodapé' | escape }}"
              loading="lazy"
            >
          </a>
        {% else %}
          <img
            class="footer-custom-image footer-image-1"
            src="{{ section.settings.image | image_url: width: 1000 }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            alt="{{ section.settings.image.alt | default: 'Primeira imagem do rodapé' | escape }}"
            loading="lazy"
          >
        {% endif %}
      {% endif %}

      {% if section.settings.multiline_text != blank or section.settings.single_line_text != blank %}
        <div class="footer-custom-text">
          {% if section.settings.multiline_text != blank %}
            <span class="footer-description">
              {{ section.settings.multiline_text }}
            </span>
          {% endif %}

          {% if section.settings.single_line_text != blank %}
            <span class="footer-custom-title">
              {{ section.settings.single_line_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if section.settings.image_2 != blank %}
      <div class="footer-secondary-row">
        {% if section.settings.image_url_2 != blank %}
          <a
            class="footer-custom-image-link"
            href="{{ section.settings.image_url_2 }}"
          >
            <img
              class="footer-custom-image footer-image-2"
              src="{{ section.settings.image_2 | image_url: width: 1000 }}"
              width="{{ section.settings.image_2.width }}"
              height="{{ section.settings.image_2.height }}"
              alt="{{ section.settings.image_2.alt | default: 'Segunda imagem do rodapé' | escape }}"
              loading="lazy"
            >
          </a>
        {% else %}
          <img
            class="footer-custom-image footer-image-2"
            src="{{ section.settings.image_2 | image_url: width: 1000 }}"
            width="{{ section.settings.image_2.width }}"
            height="{{ section.settings.image_2.height }}"
            alt="{{ section.settings.image_2.alt | default: 'Segunda imagem do rodapé' | escape }}"
            loading="lazy"
          >
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>
