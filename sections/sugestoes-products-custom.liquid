{% if article.metafields.article.products.value %}
  <style>
    #sugestoes_products_custom {
      display: grid;
      grid-template-rows: repeat(2, max-content);
      gap: 0.5rem;
      margin-top: 1rem;
      position: relative;
    }

    #sugestoes_products_custom > ul.related-track {
      display: flex;
      gap: 0.35rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: none;
      scroll-behavior: auto;
      padding-inline: clamp(12px, 4vw, 48px);
      padding-block: 0;
      list-style: none;
      margin: 0;
      padding: 0;
      cursor: grab;
      user-select: none;
      scrollbar-width: none;
      touch-action: pan-y;
    }

    #sugestoes_products_custom .related-track a,
    #sugestoes_products_custom .related-track img {
      -webkit-user-drag: none;
      user-drag: none;
    }

    #sugestoes_products_custom > ul.related-track::-webkit-scrollbar {
      display: none;
    }

    #sugestoes_products_custom .related-track.is-dragging a {
      pointer-events: none;
    }

    #sugestoes_products_custom > ul.related-track.is-dragging {
      cursor: grabbing;
    }

    #sugestoes_products_custom > ul.related-track > li.product_item_custom {
      flex: 0 0 auto;
      width: clamp(220px, 23vw, 350px);
      scroll-snap-align: none;
      scroll-snap-stop: normal;
    }

    #sugestoes_products_custom > ul.related-track > li:not(.product_item_custom) {
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }

    #sugestoes_products_custom > h1 {
      font-size: 1.75rem;
      font-weight: 700;
      margin: 0;
    }

    #sugestoes_products_custom img {
      -webkit-user-drag: none;
      user-drag: none;
    }

    #sugestoes_products_custom::before,
    #sugestoes_products_custom::after {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: clamp(18px, 4vw, 56px);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.15s ease;
      z-index: 5;
    }

    #sugestoes_products_custom::before {
      left: 0;
      background: linear-gradient(to right, rgba(255,255,255,1), rgba(255,255,255,0));
    }

    #sugestoes_products_custom::after {
      right: 0;
      background: linear-gradient(to left, rgba(255,255,255,1), rgba(255,255,255,0));
    }

    #sugestoes_products_custom.can-scroll-left::before {
      opacity: 1;
    }
    #sugestoes_products_custom.can-scroll-right::after {
      opacity: 1;
    }

    #sugestoes_products_custom > ul.related-track.is-dragging > li {
      transform: scale(0.985);
      transition: transform 0.12s ease;
    }

    #sugestoes_products_custom {
      margin: 2rem var(--desktop-container-gutter);
    }

    @media screen and (min-width: 1499px) {
      #sugestoes_products_custom {
        margin: 2rem 9vw;
      }
    }

    @media screen and (min-width: 2559px) {
      #sugestoes_products_custom {
        margin: 2rem 18vw;
      }
    }

    @media screen and (max-width: 1499px) {
      #sugestoes_products_custom > ul > .product_item_custom {
        width: 300px;
      }
    }

    @media screen and (max-width: 1000px) {
      #sugestoes_products_custom > ul {
        overflow: auto;
      }

      #sugestoes_products_custom > ul > .product_item_custom {
        width: 250px;
      }

      #sugestoes_products_custom > h1 {
        font-size: 1.25rem;
      }

      #sugestoes_products_custom {
        margin: 1rem var(--mobile-container-gutter);
      }

      #sugestoes_products_custom > ul.related-track {
        touch-action: auto;
        cursor: auto;
        user-select: auto;
      }
    }
  </style>

  <div id="sugestoes_products_custom">
    <h1>{{ section.settings.title }}</h1>

    <ul class="related-track">
      {% for p in article.metafields.article.products.value limit: 12 %}
        {% render 'product-item-2'
          , product: p %}
      {% endfor %}
    </ul>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const wrapper = document.getElementById('sugestoes_products_custom');
      const track = wrapper?.querySelector(':scope > ul.related-track');
      if (!wrapper || !track) return;

      // Bloqueia drag nativo (imagens/links) – inofensivo no mobile
      track.addEventListener('dragstart', (e) => e.preventDefault());

      const IGNORE_SELECTOR = 'input, select, textarea, option, label, button, [data-no-drag]';
      const DRAG_THRESHOLD = 10;

      const shouldIgnore = (el) => !!el.closest(IGNORE_SELECTOR);

      // Atualização das bordas (gradientes laterais) – mantida sempre ativa
      const updateEdges = () => {
        const canLeft = track.scrollLeft > 2;
        const canRight = track.scrollLeft + track.clientWidth < track.scrollWidth - 2;

        wrapper.classList.toggle('can-scroll-left', canLeft);
        wrapper.classList.toggle('can-scroll-right', canRight);

        const scrollable = track.scrollWidth > track.clientWidth + 2;
        wrapper.classList.toggle('is-scrollable', scrollable);
      };

      updateEdges();
      track.addEventListener('scroll', updateEdges, { passive: true });
      window.addEventListener('resize', updateEdges);

      // ---- Handlers do drag personalizado (apenas desktop) ----
      let isDown = false;
      let isDragging = false;
      let startX = 0;
      let startY = 0;
      let startScroll = 0;
      let pointerId = null;
      let blockClick = false;

      function onPointerDown(e) {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        if (shouldIgnore(e.target)) return;

        isDown = true;
        isDragging = false;
        blockClick = false;

        pointerId = e.pointerId;
        startX = e.clientX;
        startY = e.clientY;
        startScroll = track.scrollLeft;
      }

      function onPointerMove(e) {
        if (!isDown) return;

        const dx = e.clientX - startX;
        const dy = e.clientY - startY;

        if (!isDragging) {
          if (Math.abs(dx) < DRAG_THRESHOLD) return;
          if (Math.abs(dx) < Math.abs(dy)) return;

          isDragging = true;
          blockClick = true;

          track.classList.add('is-dragging');
          track.setPointerCapture?.(pointerId);
        }

        e.preventDefault();
        track.scrollLeft = startScroll - dx;
      }

      function onPointerUp(e) {
        if (!isDown) return;

        isDown = false;

        if (isDragging) {
          track.classList.remove('is-dragging');
          try {
            track.releasePointerCapture?.(pointerId);
          } catch (err) {}

          setTimeout(() => (blockClick = false), 200);
        }

        pointerId = null;
        isDragging = false;
      }

      function onPointerCancel(e) {
        onPointerUp(e);
      }

      function onClick(e) {
        if (!blockClick) return;
        e.preventDefault();
        e.stopPropagation();
      }

      // ---- Ativação condicional via media query ----
      function enableDrag() {
        track.addEventListener('pointerdown', onPointerDown);
        track.addEventListener('pointermove', onPointerMove);
        track.addEventListener('pointerup', onPointerUp);
        track.addEventListener('pointercancel', onPointerCancel);
        track.addEventListener('click', onClick, true);
      }

      function disableDrag() {
        track.removeEventListener('pointerdown', onPointerDown);
        track.removeEventListener('pointermove', onPointerMove);
        track.removeEventListener('pointerup', onPointerUp);
        track.removeEventListener('pointercancel', onPointerCancel);
        track.removeEventListener('click', onClick, true);
      }

      const mql = window.matchMedia('(min-width: 1001px)');

      function handleMediaChange(e) {
        if (e.matches) {
          enableDrag();
        } else {
          disableDrag();
        }
      }

      // Estado inicial
      if (mql.matches) {
        enableDrag();
      }

      // Observa mudanças (redimensionamento/orientação)
      if (mql.addEventListener) {
        mql.addEventListener('change', handleMediaChange);
      } else {
        mql.addListener(handleMediaChange); // fallback
      }
    });
  </script>
{% endif %}

{% schema %}
  {
    "name": "Sugestões products",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Titulo",
        "default": "Sugestões Bioself"
      }
    ],
    "presets": [
      {
        "name": "Sugestões products",
        "category": "blog"
      }
    ]
  }
{% endschema %}