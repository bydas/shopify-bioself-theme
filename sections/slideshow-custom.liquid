{% comment %}
  Slideshow Custom
  - Preload apenas da primeira imagem visível
  - Desktop/mobile com media query
  - URLs do preload compatíveis com os URLs usados no picture
{% endcomment %}

{% if section.blocks.size > 0 %}
  {% assign first_slide = section.blocks | first %}

  {% if first_slide.settings.image_desktop %}
    <link
      rel="preload"
      as="image"
      href="{{ first_slide.settings.image_desktop | image_url: width: 1800 }}"
      media="(min-width: 769px)"
    >
  {% endif %}

  {% if first_slide.settings.image_mobile %}
    <link
      rel="preload"
      as="image"
      href="{{ first_slide.settings.image_mobile | image_url: width: 900 }}"
      media="(max-width: 768px)"
    >
  {% endif %}
{% endif %}

<style>
  #slideshow-{{ section.id }}.custom_slideshow {
    display: grid;
    grid-auto-rows: max-content;
    grid-auto-flow: row;
    gap: 1rem;
  }

  #slideshow-{{ section.id }} .slideshow-container {
    position: relative;
    max-width: 100%;
    overflow: hidden;
  }

  #slideshow-{{ section.id }} .slide {
    display: none;
    width: 100%;
    height: auto;
    position: relative;
    cursor: grab;
    transition: transform 0.5s ease;
  }

  #slideshow-{{ section.id }} .slide.is-active {
    display: block;
  }

  #slideshow-{{ section.id }} .slide:active {
    cursor: grabbing;
  }

  #slideshow-{{ section.id }} .slideshow-container img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 1080px;
    object-fit: cover;
  }

  @media screen and (max-width: 1000px) {
    #slideshow-{{ section.id }}.custom_slideshow {
      margin: 0 var(--mobile-container-gutter) 1rem var(--mobile-container-gutter);
    }

    #slideshow-{{ section.id }} .slideshow-container img {
      max-height: 600px;
      border-radius: 0.65rem;
    }

    #slideshow-{{ section.id }} .slide {
      cursor: grab;
    }
  }

  #slideshow-{{ section.id }} .dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    z-index: 5;
  }

  #slideshow-{{ section.id }} .dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    background-color: white;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #slideshow-{{ section.id }} .dot.active-slide {
    width: 35px;
    border-radius: 5px;
    background-color: white;
  }

  #slideshow-{{ section.id }} .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    z-index: 4;
    border-radius: 50%;
  }

  @media screen and (min-width: 1000px) {
    #slideshow-{{ section.id }} .arrow {
      opacity: 0;
      visibility: hidden;
      transition: all 0.15s ease;
    }

    #slideshow-{{ section.id }} .slideshow-container:hover > .arrow {
      opacity: 1;
      visibility: visible;
    }
  }

  @media screen and (max-width: 1000px) {
    #slideshow-{{ section.id }} .arrow {
      display: none;
    }
  }

  #slideshow-{{ section.id }} .arrow-left {
    left: 10px;
    transform: translateY(-50%) rotate(180deg);
  }

  #slideshow-{{ section.id }} .arrow-right {
    right: 10px;
  }

  #slideshow-{{ section.id }} .arrow svg {
    fill: #ffffff;
    width: 14px;
    height: 14px;
  }

  #slideshow-{{ section.id }} .arrow:hover {
    background-color: rgba(0, 0, 0, 0.7);
  }
</style>

<section id="slideshow-{{ section.id }}" class="custom_slideshow">
  <div class="slideshow-container">
    {% if section.blocks.size > 1 %}
      <div class="arrow arrow-left" aria-label="Slide anterior">
        <svg xmlns="http://www.w3.org/2000/svg" height="14" width="8.75" viewBox="0 0 320 512">
          <path fill="#ffffff" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/>
        </svg>
      </div>

      <div class="arrow arrow-right" aria-label="Slide seguinte">
        <svg xmlns="http://www.w3.org/2000/svg" height="14" width="8.75" viewBox="0 0 320 512">
          <path fill="#ffffff" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/>
        </svg>
      </div>
    {% endif %}

    {% for slide in section.blocks %}
      {% assign desktop_image = slide.settings.image_desktop %}
      {% assign mobile_image = slide.settings.image_mobile %}
      {% assign fallback_image = desktop_image %}

      {% if fallback_image == blank %}
        {% assign fallback_image = mobile_image %}
      {% endif %}

      {% if fallback_image != blank %}
        {% assign desktop_image_url = desktop_image | image_url: width: 1800 %}
        {% assign mobile_image_url = mobile_image | image_url: width: 900 %}
        {% assign fallback_image_url = fallback_image | image_url: width: 1800 %}

        <div class="slide{% if forloop.first %} is-active{% endif %}">
          <a href="{{ slide.settings.link | default: '#' }}">
            <picture>
              {% if mobile_image != blank %}
                <source
                  media="(max-width: 768px)"
                  srcset="{{ mobile_image_url }}"
                >
              {% endif %}

              <img
                src="{% if desktop_image != blank %}{{ desktop_image_url }}{% else %}{{ fallback_image_url }}{% endif %}"
                alt="{{ fallback_image.alt | default: 'Slide' | escape }}"
                width="{{ fallback_image.width }}"
                height="{{ fallback_image.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                fetchpriority="{% if forloop.first %}high{% else %}auto{% endif %}"
              >
            </picture>
          </a>
        </div>
      {% endif %}
    {% endfor %}

    {% if section.blocks.size > 1 %}
      <div class="dots">
        {% for slide in section.blocks %}
          <span class="dot{% if forloop.first %} active-slide{% endif %}" data-index="{{ forloop.index }}"></span>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    const sectionEl = document.querySelector('#slideshow-{{ section.id }}');

    if (!sectionEl || sectionEl.dataset.initialized === 'true') return;

    sectionEl.dataset.initialized = 'true';

    const slides = sectionEl.querySelectorAll('.slide');
    const dots = sectionEl.querySelectorAll('.dot');
    const leftArrow = sectionEl.querySelector('.arrow-left');
    const rightArrow = sectionEl.querySelector('.arrow-right');

    let slideIndex = 0;
    let autoSlideInterval = null;
    const slideTime = parseInt('{{ section.settings.slide_time | default: 5 }}', 10) * 1000;

    if (!slides.length) return;

    function showSlides() {
      slides.forEach((slide, index) => {
        slide.classList.toggle('is-active', index === slideIndex);
      });

      dots.forEach((dot, index) => {
        dot.classList.toggle('active-slide', index === slideIndex);
      });
    }

    function autoSlide() {
      if (slides.length <= 1) return;

      slideIndex = (slideIndex + 1) % slides.length;
      showSlides();
    }

    function resetAutoSlide() {
      if (slides.length <= 1) return;

      clearInterval(autoSlideInterval);
      autoSlideInterval = setInterval(autoSlide, slideTime);
    }

    function changeSlide(direction) {
      if (slides.length <= 1) return;

      slideIndex = (slideIndex + direction + slides.length) % slides.length;
      showSlides();
      resetAutoSlide();
    }

    function currentSlide(index) {
      slideIndex = index - 1;
      showSlides();
      resetAutoSlide();
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        currentSlide(Number(dot.dataset.index));
      });
    });

    leftArrow?.addEventListener('click', () => changeSlide(-1));
    rightArrow?.addEventListener('click', () => changeSlide(1));

    function handleDrag() {
      let startX = 0;
      let isDragging = false;

      slides.forEach((slide) => {
        slide.addEventListener('mousedown', (event) => {
          event.preventDefault();
          startX = event.clientX;
          isDragging = true;
          slide.style.cursor = 'grabbing';
        });

        slide.addEventListener(
          'touchstart',
          (event) => {
            startX = event.touches[0].clientX;
            isDragging = true;
            slide.style.cursor = 'grabbing';
          },
          { passive: true }
        );

        slide.addEventListener('mousemove', (event) => {
          if (!isDragging) return;

          const currentX = event.clientX;
          const diffX = startX - currentX;

          if (Math.abs(diffX) > 50) {
            changeSlide(diffX > 0 ? 1 : -1);
            isDragging = false;
          }
        });

        slide.addEventListener(
          'touchmove',
          (event) => {
            if (!isDragging) return;

            const currentX = event.touches[0].clientX;
            const diffX = startX - currentX;

            if (Math.abs(diffX) > 50) {
              changeSlide(diffX > 0 ? 1 : -1);
              isDragging = false;
            }
          },
          { passive: true }
        );

        slide.addEventListener('mouseup', () => {
          isDragging = false;
          slide.style.cursor = 'grab';
        });

        slide.addEventListener('mouseleave', () => {
          isDragging = false;
          slide.style.cursor = 'grab';
        });

        slide.addEventListener('touchend', () => {
          isDragging = false;
          slide.style.cursor = 'grab';
        });
      });
    }

    showSlides();
    handleDrag();

    if (slides.length > 1) {
      autoSlideInterval = setInterval(autoSlide, slideTime);
    }

    document.addEventListener('shopify:section:unload', function (event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        clearInterval(autoSlideInterval);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Slideshow Custom",
  "settings": [
    {
      "type": "number",
      "id": "slide_time",
      "label": "Tempo de troca de slides (em segundos)",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Slide para Desktop"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Slide para Mobile"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link do Slide"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow Custom",
      "category": "Custom",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
