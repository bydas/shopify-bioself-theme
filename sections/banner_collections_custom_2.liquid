{%- liquid
  assign banner_desktop = blank
  assign banner_mobile = blank
  assign banner_alt = collection.title
  assign banner_source = blank

  assign current_collection_is_brand = false

  comment
    Regra 1: a coleção é marca quando usa o template "brand".
  endcomment
  if collection.template_suffix == 'brand'
    assign current_collection_is_brand = true
  endif

  comment
    Regra 2: a coleção é marca quando está no menu com handle "pagina-marcas".
    A verificação cobre até três níveis do menu.
  endcomment
  unless current_collection_is_brand
    assign brands_menu = linklists['pagina-marcas']

    if brands_menu != blank
      for brand_link_level_1 in brands_menu.links
        assign brand_collection_level_1 = brand_link_level_1.object

        if brand_collection_level_1 != blank and brand_collection_level_1.id == collection.id
          assign current_collection_is_brand = true
          break
        endif

        for brand_link_level_2 in brand_link_level_1.links
          assign brand_collection_level_2 = brand_link_level_2.object

          if brand_collection_level_2 != blank and brand_collection_level_2.id == collection.id
            assign current_collection_is_brand = true
            break
          endif

          for brand_link_level_3 in brand_link_level_2.links
            assign brand_collection_level_3 = brand_link_level_3.object

            if brand_collection_level_3 != blank and brand_collection_level_3.id == collection.id
              assign current_collection_is_brand = true
              break
            endif
          endfor

          if current_collection_is_brand
            break
          endif
        endfor

        if current_collection_is_brand
          break
        endif
      endfor
    endif
  endunless

  comment
    PRIORIDADE 1: bloco da secção associado à coleção atual.

    Apenas o primeiro bloco correspondente é usado. Desta forma, mesmo que a
    coleção seja selecionada em vários blocos, o banner nunca é duplicado.
  endcomment
  for block in section.blocks
    assign block_collection = block.settings.collection

    if block_collection != blank and block_collection.id == collection.id
      if block.settings.image_desktop != blank or block.settings.image_mobile != blank
        assign banner_desktop = block.settings.image_desktop
        assign banner_mobile = block.settings.image_mobile
        assign banner_source = 'block'

        if block.settings.alt_text != blank
          assign banner_alt = block.settings.alt_text
        endif

        break
      endif
    endif
  endfor

  comment
    PRIORIDADE 2: metafields da coleção.

    Só são usados quando:
    - não existe banner proveniente de um bloco;
    - a coleção atual não é uma marca;
    - existe pelo menos uma das imagens nos metafields.
  endcomment
  if banner_source == blank and current_collection_is_brand == false
    assign metafield_banner_desktop = collection.metafields.custom.imagem_de_container.value
    assign metafield_banner_mobile = collection.metafields.custom.imagem_de_container_mobile.value

    if metafield_banner_desktop != blank or metafield_banner_mobile != blank
      assign banner_desktop = metafield_banner_desktop
      assign banner_mobile = metafield_banner_mobile
      assign banner_source = 'metafield'
    endif
  endif

  comment
    Fallback responsivo:
    - se não houver imagem mobile, usa a desktop;
    - se não houver imagem desktop, usa a mobile.
  endcomment
  if banner_desktop == blank and banner_mobile != blank
    assign banner_desktop = banner_mobile
  endif

  if banner_mobile == blank and banner_desktop != blank
    assign banner_mobile = banner_desktop
  endif
-%}

{%- if banner_desktop != blank or banner_mobile != blank -%}
  <section
    id="banner-custom-{{ section.id }}"
    class="banner-custom"
    data-banner-source="{{ banner_source }}"
    {% if banner_source == 'block' %}
      {{ block.shopify_attributes }}
    {% endif %}
  >
    <picture class="banner-custom__picture">
      {%- if banner_mobile != blank -%}
        <source
          media="(max-width: 749px)"
          srcset="
            {{ banner_mobile | image_url: width: 375 }} 375w,
            {{ banner_mobile | image_url: width: 550 }} 550w,
            {{ banner_mobile | image_url: width: 750 }} 750w,
            {{ banner_mobile | image_url: width: 1000 }} 1000w
          "
          sizes="100vw"
        >
      {%- endif -%}

      {{
        banner_desktop
        | image_url: width: 2400
        | image_tag:
          class: 'banner-custom__image',
          widths: '750, 1000, 1200, 1500, 1800, 2000, 2400',
          sizes: '100vw',
          loading: 'eager',
          fetchpriority: 'high',
          alt: banner_alt
      }}
    </picture>
  </section>
{%- endif -%}

<style>
  #banner-custom-{{ section.id }} {
    display: block;
    width: 100%;
    margin: 0;
    overflow: hidden;
  }

  #banner-custom-{{ section.id }} .banner-custom__picture {
    display: block;
    width: 100%;
  }

  #banner-custom-{{ section.id }} .banner-custom__image {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
    object-fit: cover;
  }
</style>

{% schema %}
{
  "name": "Banner custom",
  "settings": [],
  "blocks": [
    {
      "type": "collection_banner",
      "name": "Banner de coleção",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Imagem desktop"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Imagem mobile"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Texto alternativo da imagem",
          "info": "Quando vazio, será utilizado o nome da coleção."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner custom",
      "category": "collection"
    }
  ]
}
{% endschema %}
