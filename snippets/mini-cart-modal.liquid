<style>
  #mini-cart-modal {
    position: fixed;
    top: 0;
    right: 0;
    height: 100%;
    z-index: 5000;
    background: white;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    width: 500px;
    transform: translateX(100%);
  }

  @keyframes mini-cart-modal-slide-in {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(0);
    }
  }

  @keyframes mini-cart-modal-slide-out {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(100%);
    }
  }

  #mini-cart-modal.is-visible {
    animation: mini-cart-modal-slide-in 0.3s forwards;
  }

  #mini-cart-modal.is-hidden {
    animation: mini-cart-modal-slide-out 0.3s forwards;
  }

  #mini-cart-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
  }

  #mini-cart-modal-header h3 {
    font-weight: 600;
    color: #258439;
    margin: 0;
    font-size: 1.25rem;
  }

  #mini-cart-modal-header svg {
    cursor: pointer;
  }

  #mini-cart-modal-items-container {
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  #mini-cart-modal-items {
    list-style: none;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
  }

  #mini-cart-modal-items li {
    border-bottom: 1px solid #88A54E40;
    padding: 1.5rem 1rem;
    display: flex;
    gap: 2rem;
  }

  .mini-cart-modal-item-link {
    display: grid;
    place-content: center;
    flex-shrink: 0;
  }

  #mini-cart-modal-items li a img {
    width: 100px;
    height: 100px;
    object-fit: cover;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    flex: 1;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details a {
    text-decoration: none;
    color: #258439;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details a h4 {
    margin: 0;
    font-weight: 700 !important;
    font-size: 16px;
    max-width: 250px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: normal;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details .mini-cart-modal-item-pricing {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details .mini-cart-modal-item-pricing h5 {
    margin: 0;
    font-weight: 900 !important;
    color: #258439;
    font-size: 18px;
  }

  #mini-cart-modal-items li .mini-cart-modal-item-details .mini-cart-modal-item-pricing span {
    font-weight: 600;
    font-size: 14px;
    text-decoration: line-through;
  }

  #mini-cart-modal-footer {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-top: 1px solid #88A54E40;
    padding: 1.5rem;
  }

  #mini-cart-modal-footer div {
    display: flex;
    justify-content: space-between;
  }

  #mini-cart-modal-footer div h6 {
    margin: 0;
    font-weight: 900 !important;
    line-height: normal;
  }

  #mini-cart-modal-price-container {
    font-size: 18px;
  }

  #mini-cart-modal-footer div span {
    font-weight: 600;
    line-height: normal;
  }

  #mini-cart-modal-discounts-container {
    display: flex;
    flex-direction: column;
    list-style-type: none;
    max-height: 60px;
    overflow: auto;
  }

  .mini-cart-modal-discount_application {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 600;
  }

  .mini-cart-modal-discount_application div {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mini-cart-modal-discount_application div * {
    font-size: 15px;
  }

  .mini-cart-modal-discount_application div p {
    margin: 0;
    color: #258439;
    line-height: normal;
  }

  #mini-cart-modal-total-price {
    font-weight: 900 !important;
    color: #258439;
  }

  #mini-cart-modal-disclaimer {
    font-size: 13px;
    margin: 1rem 0 0.25rem;
  }

  #mini-cart-modal-disclaimer a {
    color: #258439;
    text-decoration: underline;
  }

  #mini-cart-modal-checkout {
    display: block;
    text-align: center;
    background-color: #258439;
    color: white;
    padding: 0.65rem;
    text-decoration: none;
    font-weight: 600;
    border-radius: 8px;
    text-transform: uppercase;
  }

  .update-quantity-modal {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    width: max-content;
    padding: 0.125rem 0.75rem;
    border: 2px solid #FFBB12;
    border-radius: 0.5rem;
  }

  .update-quantity-modal svg {
    cursor: pointer;
  }

  .update-quantity-modal input {
    font-weight: 700;
    outline: none;
    border: none;
    width: 30px;
    text-align: center;
  }

  .update-quantity-modal input {
    font-size: 1.05rem;
  }

  .update-quantity-modal input:focus {
    outline: none;
  }

  .update-quantity-modal input::-webkit-outer-spin-button,
  .update-quantity-modal input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .update-quantity-modal input[type='number'] {
    -moz-appearance: textfield;
  }

  .update-quantity-modal svg.is-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .mini-cart-modal-item-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .mini-cart-modal-item-actions span {
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
  }

  /* Mensagens */
  #mini-cart-modal-message {
    display: none;
    margin: 0 1.5rem 0.75rem;
    padding: 0.6rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.25;
    min-height: 50px;
    max-height: 84px;
    overflow-y: auto;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    border: 1px solid transparent;
  }
  #mini-cart-modal-message.is-visible {
    display: block;
  }
  #mini-cart-modal-message.is-error {
    background: #fff1f1;
    border-color: #ffb3b3;
    color: #7a1111;
  }
  #mini-cart-modal-message.is-info {
    background: #f0fbff;
    border-color: #a8e7ff;
    color: #0b4a63;
  }

  /* Loading overlay (bloqueia tudo) */
  #mini-cart-modal-loading {
    display: none;
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.65);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(1px);
  }
  #mini-cart-modal.is-loading #mini-cart-modal-loading {
    display: flex;
  }

  /* Spinner */
  .mini-cart-modal-spinner {
    width: 18px;
    height: 18px;
    border: 2px solid rgba(0, 0, 0, 0.15);
    border-top-color: rgba(0, 0, 0, 0.55);
    border-radius: 50%;
    animation: miniCartModalSpin 0.7s linear infinite;
  }
  @keyframes miniCartModalSpin {
    to {
      transform: rotate(360deg);
    }
  }

  /* Desativar cliques (extra safety) */
  #mini-cart-modal.is-loading {
    pointer-events: none;
    /* impede cliques em tudo */
  }
  #mini-cart-modal.is-loading #mini-cart-modal-loading {
    pointer-events: all;
    /* overlay continua a receber eventos */
  }

  /* Desativar controlos por linha */
  .update-quantity-modal svg.is-disabled {
    opacity: 0.35;
    pointer-events: none;
  }
  .update-quantity-modal input:disabled {
    opacity: 0.65;
  }

  #mini-cart-modal-biopoints {
    display: grid;
    place-items: center;
    text-align: center;
    background-color: #EEF5EF;
    border-radius: 8px;
    padding: 1rem;
    margin: 1.5rem;
    gap: 1rem;
  }

  #mini-cart-modal-biopoints h6 {
    margin: 0;
    font-weight: 700;
    font-size: 16px;
    color: #258439;
    line-height: 1.25;
    width: 70%;
  }

  #mini-cart-modal-biopoints a {
    background-color: #FFBB12;
    text-decoration: none;
    font-weight: 700;
    border-radius: 8px;
    padding: 0.25rem 2rem;
    width: max-content;
    text-transform: uppercase;
    text-align: center;
  }

  #mini-cart-modal-cruz-vermelha {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 0 1.5rem 1.5rem;
    gap: 1rem;
    cursor: pointer;
    transition: opacity 0.3s;
  }

  #mini-cart-modal-cruz-vermelha:hover {
    opacity: 0.5;
  }

  #mini-cart-modal-cruz-vermelha span {
    color: #258439;
    text-decoration: underline;
    font-weight: 600;
    font-size: 16px;
  }

  @media (max-width: 1000px) {
    #mini-cart-modal {
      width: 90%;
    }

    #mini-cart-modal-items li a img {
      width: 80px;
      height: 80px;
    }

    #mini-cart-modal-items li a h4 {
      max-width: 180px;
      font-size: 14px;
    }

    #mini-cart-modal-items li .mini-cart-modal-item-details .mini-cart-modal-item-pricing h5 {
      font-size: 16px;
    }

    #mini-cart-modal-items li .mini-cart-modal-item-details .mini-cart-modal-item-pricing span {
      font-size: 12px;
    }

    #mini-cart-modal-cruz-vermelha {
      flex-direction: column;
    }

    #mini-cart-modal-cruz-vermelha span {
      font-size: 14px;
    }

    .update-quantity-modal {
      gap: 1rem;
    }
  }

  @media (max-width: 400px) {
    .mini-cart-modal-item-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>

<div id="mini-cart-modal">
  <div id="mini-cart-modal-header">
    <h3>O meu carrinho</h3>

    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      xmlns="http://www.w3.org/2000/svg">
      <path d="M1.4 14L0 12.6L5.6 7L0 1.4L1.4 0L7 5.6L12.6 0L14 1.4L8.4 7L14 12.6L12.6 14L7 8.4L1.4 14Z" fill="#258439" />
    </svg>
  </div>

  <div id="mini-cart-modal-loading" aria-hidden="true">
    <div class="mini-cart-spinner"></div>
  </div>

  <div
    id="mini-cart-modal-message"
    role="alert"
    aria-live="polite"></div>

  <div id="mini-cart-modal-items-container">
    <ul id="mini-cart-modal-items">
      {% for item in cart.items %}
        <li
          data-line="{{ forloop.index }}"
          data-key="{{ item.key | escape }}"
          data-variant-id="{{ item.variant_id }}"
          data-max="{% if item.variant.inventory_management and item.variant.inventory_policy == 'deny' %}{{ item.variant.inventory_quantity }}{% else %}{% endif %}">
          <a class="mini-cart-modal-item-link" href="{{ item.url }}">
            <img src="{{ item.image | img_url: 'small' }}" alt="{{ item.title }}">
          </a>

          <div class="mini-cart-modal-item-details">
            <a href="{{ item.url }}">
              <h4>{{ item.product.title }}</h4>
            </a>

            <div class="mini-cart-modal-item-pricing">
              <h5>{{ item.final_price | money }}</h5>

              {% if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price %}
                <span class="mini-cart-modal-compare">{{ item.variant.compare_at_price | money }}</span>
              {% endif %}
            </div>

            <div class="mini-cart-modal-item-actions">
              <div class="update-quantity-modal">
                <svg
                  class="js-dec"
                  width="14"
                  height="15"
                  viewBox="0 0 14 15"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path d="M2.5 15C2.04167 15 1.64931 14.8368 1.32292 14.5104C0.996528 14.184 0.833333 13.7917 0.833333 13.3333V2.5H0V0.833333H4.16667V0H9.16667V0.833333H13.3333V2.5H12.5V13.3333C12.5 13.7917 12.3368 14.184 12.0104 14.5104C11.684 14.8368 11.2917 15 10.8333 15H2.5ZM10.8333 2.5H2.5V13.3333H10.8333V2.5ZM4.16667 11.6667H5.83333V4.16667H4.16667V11.6667ZM7.5 11.6667H9.16667V4.16667H7.5V11.6667Z" fill="#1C1B1F" />
                </svg>

                <input
                  id="mini-cart-modal-quantity-{{ forloop.index }}"
                  name="quantity"
                  type="number"
                  value="{{ item.quantity }}"
                  min="1"
                  step="1"
                  max="999">

                <svg
                  class="js-inc"
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 6.66667H0V5H5V0H6.66667V5H11.6667V6.66667H6.66667V11.6667H5V6.66667Z" fill="black" />
                </svg>
              </div>

              <span class="js-remove">Remover</span>
            </div>
          </div>
        </li>
      {% endfor %}
    </ul>

    {% unless customer %}
      <div id="mini-cart-modal-biopoints">
        <h6>Adere ao Plano Biopoints e recebe descontos nas tuas compras.</h6>
        <a href="/pages/biopoints">Aderir Já</a>
      </div>
    {% endunless %}

    {% assign has_cvp_discount = false %}

    {% for discount in cart.discount_applications %}
      {% if discount.title contains 'CVP-' %}
        {% assign has_cvp_discount = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% unless has_cvp_discount %}
      <div style="{% if customer %}margin-top: 1.5rem;{% endif %}" id="mini-cart-modal-cruz-vermelha">
        <img src="{{ 'cruz_vermelha_logo.png' | asset_url }}" alt="Cruz Vermelha">

        <span>
          Ativar Desconto Cruz Vermelha
        </span>
      </div>
    {% endunless %}
  </div>

  <div id="mini-cart-modal-footer">
    <div id="mini-cart-modal-price-container">
      <h6>Total</h6>

      <span id="mini-cart-modal-total-price">{{ cart.total_price | money }}</span>
    </div>

    {% unless cart.discount_applications.size == 0 %}
      <ul id="mini-cart-modal-discounts-container">
        {% for discount in cart.discount_applications %}
          <li data-title="{{- discount.title -}}" class="mini-cart-modal-discount_application">
            <div>
              <p>Desconto:</p>

              <span>
                {%- if discount.title contains 'CVP-' -%}
                  Cruz Vermelha Portuguesa
                {%- else -%}
                  {{- discount.title -}}
                {%- endif -%}
              </span>
            </div>

            <span class="mini-cart-modal-discount-price">{{ discount.total_allocated_amount | money }}</span>
          </li>
        {% endfor %}
      </ul>
    {% endunless %}

    <div>
      <span>Valor poupado</span>

      <span id="mini-cart-modal-total-discount">{{ cart.total_discount | money }}</span>
    </div>

    <span id="mini-cart-modal-disclaimer">Imposto incluído.
      <a href="/policies/shipping-policy">Envio</a>
      e descontos calculados na finalização da compra.</span>

    <a id="mini-cart-modal-checkout" href="/checkout">Finalizar compra</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const cruzVermelhaButton = document.querySelector('#mini-cart-modal-cruz-vermelha');

    cruzVermelhaButton?.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();

      const overlay = document.querySelector('#modal_overlay');
      const modal = document.querySelector('#modal_cruz_vermelha');

      if (overlay && modal) {
        overlay.style.zIndex = '5001';
        overlay.style.display = 'block';
        modal.style.opacity = '1';
        modal.style.visibility = 'visible';
      }
    });
  });

  (function () {
    function boot() {
      if (!window.BYDasMiniCart) return;

      window.BYDasMiniCart.mountModal({
        modalId: 'mini-cart-modal',
        itemsId: 'mini-cart-modal-items',
        totalId: 'mini-cart-modal-total-price',
        discountId: 'mini-cart-modal-total-discount',
        messageId: 'mini-cart-modal-message',
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
</script>