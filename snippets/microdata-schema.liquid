{%- comment -%}
  This snippet structures the micro-data using JSON-LD specification.
  Please note that for Product especially, the schema often changes.
  We try to output as much info as possible, but Google may add new requirements over time,
  or change the format of some info.
{%- endcomment -%}

{%- if request.page_type == 'product' -%}
  {%- assign days_product_price_valid_until = 10 | times: 86400 -%}

  {%- assign gtin_option = 'gtin' -%}
  {%- assign is_barcode_available = false -%}
  {%- assign is_valid_gtin_length = false -%}

  {%- if product.selected_or_first_available_variant.barcode != blank -%}
    {%- assign is_barcode_available = true -%}
    {%- assign gtin_string_length = product.selected_or_first_available_variant.barcode | size -%}

    {%- if gtin_string_length == 8
      or gtin_string_length == 12
      or gtin_string_length == 13
      or gtin_string_length == 14
    -%}
      {%- assign is_valid_gtin_length = true -%}
      {%- assign gtin_option = gtin_option | append: gtin_string_length -%}
    {%- endif -%}
  {%- endif -%}

  {%- assign product_url = shop.url | append: product.url -%}
  {%- assign product_image = product.featured_media.preview_image | default: product.featured_image -%}

  {%- if product_image != blank -%}
    {%- assign product_image_url = product_image | image_url: width: 1024 | prepend: 'https:' -%}
  {%- endif -%}

  {%- capture main_entity_microdata -%}
    "@type": "Product",
    "offers": [
      {%- for variant in product.variants -%}
        {%- assign variant_url = shop.url | append: product.url | append: '?variant=' | append: variant.id -%}
        {
          "@type": "Offer",
          "name": {{ variant.title | json }},
          "availability": {%- if variant.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
          "price": {{ variant.price | divided_by: 100.0 | json }},
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "priceValidUntil": {{ 'now' | date: '%s' | plus: days_product_price_valid_until | date: '%Y-%m-%d' | json }},
          {%- if variant.sku != blank -%}
            "sku": {{ variant.sku | json }},
          {%- endif -%}
          "url": {{ variant_url | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ],
    {%- if is_barcode_available and is_valid_gtin_length -%}
      "{{ gtin_option }}": {{ product.selected_or_first_available_variant.barcode | json }},
      "productId": {{ product.selected_or_first_available_variant.barcode | json }},
    {%- elsif is_barcode_available -%}
      "mpn": {{ product.selected_or_first_available_variant.barcode | json }},
      "productId": {{ product.selected_or_first_available_variant.barcode | json }},
    {%- endif -%}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | json }},
    "category": {{ product.type | json }},
    "url": {{ product_url | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | json }}
    {%- if product_image != blank -%}
      ,
      "image": {
        "@type": "ImageObject",
        "url": {{ product_image_url | json }},
        "image": {{ product_image_url | json }},
        "name": {{ product_image.alt | default: product.title | json }},
        "width": "1024",
        "height": "1024"
      }
    {%- endif -%}
  {%- endcapture -%}

{%- elsif request.page_type == 'article' -%}
  {%- assign article_url = shop.url | append: article.url -%}
  {%- assign article_author_tag = blank -%}
  {%- assign article_category_tag = blank -%}

  {%- for tag in article.tags -%}
    {%- if tag contains 'author_' and article_author_tag == blank -%}
      {%- assign article_author_tag = tag -%}
    {%- elsif article_category_tag == blank -%}
      {%- assign article_category_tag = tag -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if article.image != blank -%}
    {%- assign article_image_url = article.image | image_url: width: 1024 | prepend: 'https:' -%}
  {%- endif -%}

  {%- capture main_entity_microdata -%}
    "@type": "BlogPosting",
    "mainEntityOfPage": {{ article_url | json }},
    "articleSection": {{ blog.title | json }},
    "keywords": {{ article.tags | join: ', ' | json }},
    "headline": {{ article.title | json }},
    "description": {{ article.excerpt_or_content | strip_html | truncatewords: 25 | json }},
    "dateCreated": {{ article.created_at | date: '%Y-%m-%dT%T' | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%T' | json }},
    "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%T' | json }},
    {%- if article.image != blank -%}
      "image": {
        "@type": "ImageObject",
        "url": {{ article_image_url | json }},
        "image": {{ article_image_url | json }},
        "name": {{ article.image.alt | default: article.title | json }},
        "width": "1024",
        "height": "1024"
      },
    {%- endif -%}
    "author": {
      "@type": "Person"
      {%- if article_author_tag != blank -%}
        {%- assign article_author_tag_handle = article_author_tag | handleize -%}
        {%- assign tag_handle = article_author_tag | split: '_' | last | handleize -%}
        {%- assign author = shop.metaobjects['autores'][tag_handle].nome.value -%}
        {%- assign author_url = shop.url | append: blog.url | append: '/tagged/' | append: article_author_tag_handle -%}
        ,
        "name": {{ author | default: shop.name | json }},
        "url": {{ author_url | json }}
      {%- else -%}
        ,
        "name": {{ shop.name | json }}
      {%- endif -%}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    },
    "commentCount": {{ article.comments_count | json }},
    "comment": [
      {%- for comment in article.comments limit: 5 -%}
        {
          "@type": "Comment",
          "author": {{ comment.author | json }},
          "datePublished": {{ comment.created_at | date: '%Y-%m-%dT%T' | json }},
          "text": {{ comment.content | strip_html | json }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  {%- endcapture -%}
{%- endif -%}

{%- capture breadcrumb_entity_microdata -%}
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'general.breadcrumb.home' | t | json }},
      "item": {{ shop.url | json }}
    }

    {%- if request.page_type == 'product' -%}
      {%- assign breadcrumb_collection = collection -%}

      {%- if breadcrumb_collection == blank and product.collections.size > 0 -%}
        {%- assign breadcrumb_collection = product.collections | first -%}
      {%- endif -%}

      {%- if breadcrumb_collection != blank -%}
        {%- assign breadcrumb_collection_url = shop.url | append: breadcrumb_collection.url -%}
        {%- assign breadcrumb_product_url = shop.url | append: product.url | within: breadcrumb_collection -%}

        ,
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ breadcrumb_collection.title | json }},
          "item": {{ breadcrumb_collection_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ product.title | json }},
          "item": {{ breadcrumb_product_url | json }}
        }
      {%- else -%}
        ,
        {
          "@type": "ListItem",
          "position": 2,
          "name": {{ product.title | json }},
          "item": {{ product_url | json }}
        }
      {%- endif -%}

    {%- elsif request.page_type == 'collection' -%}
      {%- assign collections_url = shop.url | append: '/collections' -%}
      {%- assign collection_url = shop.url | append: collection.url -%}

      ,
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Coleções",
        "item": {{ collections_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ collection.title | json }},
        "item": {{ collection_url | json }}
      }

    {%- elsif request.page_type == 'blog' -%}
      {%- assign blog_url = shop.url | append: blog.url -%}

      ,
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ blog_url | json }}
      }

      {%- if request.path contains 'tagged' -%}
        {%- assign current_tag = request.path | split: '/' | last -%}
        {%- assign current_tag_url = shop.url | append: blog.url | append: '/tagged/' | append: current_tag -%}

        {%- unless current_tag contains 'author' -%}
          ,
          {
            "@type": "ListItem",
            "position": 3,
            "name": {{ current_tags | join: ', ' | json }},
            "item": {{ current_tag_url | json }}
          }
        {%- endunless -%}
      {%- endif -%}

    {%- elsif request.page_type == 'article' -%}
      {%- assign blog_url = shop.url | append: blog.url -%}

      ,
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ blog_url | json }}
      }

      {%- if article_category_tag != blank -%}
        {%- assign article_category_url = shop.url | append: blog.url | append: '/tagged/' | append: article_category_tag | handleize -%}

        ,
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ article_category_tag | json }},
          "item": {{ article_category_url | json }}
        },
        {
          "@type": "ListItem",
          "position": 4,
          "name": {{ article.title | json }},
          "item": {{ article_url | json }}
        }
      {%- else -%}
        ,
        {
          "@type": "ListItem",
          "position": 3,
          "name": {{ article.title | json }},
          "item": {{ article_url | json }}
        }
      {%- endif -%}

    {%- elsif request.page_type == 'page' -%}
      {%- assign page_url = shop.url | append: page.url -%}

      ,
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ page.title | json }},
        "item": {{ page_url | json }}
      }
    {%- endif -%}
  ]
{%- endcapture -%}

{%- if main_entity_microdata != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      {{ main_entity_microdata }}
    }
  </script>
{%- endif -%}

{%- if breadcrumb_entity_microdata != blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      {{ breadcrumb_entity_microdata }}
    }
  </script>
{%- endif -%}
